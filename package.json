{
  "name": "nocodb-cli",
  "version": "0.1.0",
  "description": "Agent-ready CLI for the NocoDB REST API (v2): bases, tables, columns, records, views, webhooks, comments, storage. Cloud & self-hosted.",
  "type": "module",
  "bin": {
    "nocodb-cli": "./dist/index.js"
  },
  "files": [
    "dist",
    "skills",
    "README.md"
  ],
  "keywords": [
    "nocodb",
    "cli",
    "api",
    "database",
    "no-code",
    "airtable",
    "spreadsheet",
    "api2cli",
    "agent-skill"
  ],
  "license": "MIT",
  "author": "Nardjo",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Nardjo/nocodb-cli.git"
  },
  "homepage": "https://github.com/Nardjo/nocodb-cli#readme",
  "bugs": {
    "url": "https://github.com/Nardjo/nocodb-cli/issues"
  },
  "scripts": {
    "build": "bun build src/index.ts --outfile dist/index.js --target bun",
    "dev": "bun run src/index.ts"
  },
  "dependencies": {
    "commander": "^13.0.0",
    "picocolors": "^1.1.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.7.0"
  }
}
